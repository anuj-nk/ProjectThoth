# Project Thoth — environment variables template
#
# This file is the COMMITTED template. It must NEVER contain real values.
# Local setup:
#   1. cp .env.example .env
#   2. Fill in real values in .env (which is gitignored).
#   3. Loaded automatically in Python via `from dotenv import load_dotenv; load_dotenv()`.

# ─── LLM provider ──────────────────────────────────────────
# Thoth routes ALL chat-completion calls through OpenRouter,
# which is OpenAI-API-compatible and exposes Anthropic, OpenAI, and other
# models behind one key. Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ─── Embeddings ────────────────────────────────────────────
# OpenRouter can also serve embeddings, but its embedding catalog is
# narrower than OpenAI direct. If you have an OpenAI key, the code will
# prefer it for embeddings (cheaper, more reliable). Otherwise it falls
# back to OpenRouter automatically. Get a key at
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ─── Model selection (optional overrides) ──────────────────
# Default chat model — any OpenRouter model id (e.g. anthropic/claude-sonnet-4,
# openai/gpt-4o-mini). Cheap + capable starter:
THOTH_LLM_MODEL=anthropic/claude-sonnet-4
# Default embedding model. With OPENAI_API_KEY set, use the bare model name.
# Without it, prefix with "openai/" to route through OpenRouter.
THOTH_EMBED_MODEL=text-embedding-3-small

# ─── Supabase ──────────────────────────────────────────────
# Find under Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key

# Direct Postgres connection string for LangGraph PostgresSaver + hybrid SQL.
# Find via the green "Connect" button at the top of the project page →
# Connection string → Direct connection. Replace [YOUR-PASSWORD] with the
# database password you set when the project was created (or reset it under
# Database → Settings → Reset database password).
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-ref.supabase.co:5432/postgres
