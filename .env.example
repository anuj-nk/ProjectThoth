# Project Thoth — environment variables template
# This file is the COMMITTED template. It must NEVER contain real values.
# Local setup:
#   1. cp .env.example .env.local   (for Next.js / Anuj's code)
#   2. cp .env.example .env         (for Python / Suzy's code)
#   3. Fill in real values in the copied file.

# ─── Supabase (Next.js) ────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Supabase (Python / LangGraph) ────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-ref.supabase.co:5432/postgres

# ─── LLM ──────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENAI_API_KEY=
HUGGINGFACE_API_KEY=
GROQ_API_KEY=
LLM_PROVIDER=openrouter
THOTH_LLM_MODEL=anthropic/claude-sonnet-4

# ─── Embeddings ───────────────────────────────────────────
THOTH_EMBED_MODEL=text-embedding-3-small

# ─── Retrieval ────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.75